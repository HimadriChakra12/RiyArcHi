#!/bin/bash

# ytdlp-tui-enhanced.sh - Enhanced TUI wrapper for yt-dlp with JSON organization

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Default directories
MUSIC_DIR="$HOME/Music/yt-dlp"
CONFIG_DIR="$HOME/.config/ytdlp-tui"
DATABASE_FILE="$CONFIG_DIR/downloads.json"

# UI mode: fzf, whiptail, or basic
UI_MODE=""

# Current download metadata
declare -A DOWNLOAD_META

# Initialize JSON database structure
init_database() {
    if [ ! -f "$DATABASE_FILE" ]; then
        cat > "$DATABASE_FILE" << 'EOF'
{
  "youtube": {
    "playlists": [],
    "singles": []
  },
  "soundcloud": {
    "playlists": [],
    "singles": []
  },
  "other": {
    "playlists": [],
    "singles": []
  },
  "metadata": {
    "version": "1.0",
    "last_updated": "",
    "total_downloads": 0
  }
}
EOF
        echo -e "${GREEN}✅ Database initialized${NC}"
    fi
}

# Detect source from URL
detect_source() {
    local url=$1
    if [[ "$url" == *"youtube.com"* ]] || [[ "$url" == *"youtu.be"* ]]; then
        echo "youtube"
    elif [[ "$url" == *"soundcloud.com"* ]]; then
        echo "soundcloud"
    else
        echo "other"
    fi
}

# Check if URL is playlist
is_playlist() {
    local url=$1
    if [[ "$url" == *"list="* ]] || [[ "$url" == *"playlist"* ]] || [[ "$url" == *"/sets/"* ]]; then
        return 0
    else
        return 1
    fi
}

# Add download to JSON database
add_to_database() {
    local source=$1
    local type=$2  # "playlist" or "single"
    local url=$3
    local title=$4
    local custom_name=$5
    local format=$6
    local download_date=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local file_path=$7
    
    # Escape special characters for JSON
    title=$(echo "$title" | sed 's/"/\\"/g' | sed "s/'/\\'/g")
    custom_name=$(echo "$custom_name" | sed 's/"/\\"/g' | sed "s/'/\\'/g")
    url=$(echo "$url" | sed 's/"/\\"/g')
    file_path=$(echo "$file_path" | sed 's/"/\\"/g')
    
    # Create temporary Python script for JSON manipulation
    python3 << PYEOF
import json
import sys

try:
    with open('$DATABASE_FILE', 'r') as f:
        data = json.load(f)
    
    entry = {
        "url": "$url",
        "title": "$title",
        "custom_name": "$custom_name",
        "format": "$format",
        "download_date": "$download_date",
        "file_path": "$file_path",
        "id": data['metadata']['total_downloads'] + 1
    }
    
    # Add to appropriate section
    if "$type" == "playlist":
        data['$source']['playlists'].append(entry)
    else:
        data['$source']['singles'].append(entry)
    
    # Update metadata
    data['metadata']['total_downloads'] += 1
    data['metadata']['last_updated'] = "$download_date"
    
    with open('$DATABASE_FILE', 'w') as f:
        json.dump(data, f, indent=2)
    
    print("success")
except Exception as e:
    print(f"error: {e}")
    sys.exit(1)
PYEOF
}

# Get custom name for download
get_custom_name() {
    local default_name="$1"
    local custom_name

    # UI text → stderr
    echo -e "${CYAN}📝 Custom Name (press Enter to use default)${NC}" >&2
    echo -e "${BLUE}Default: ${YELLOW}$default_name${NC}" >&2

    # Prompt must NOT be inside command substitution
    read -r -p "$(echo -e "${GREEN}✏️  Custom name: ${NC}")" custom_name

    if [ -z "$custom_name" ]; then
        custom_name="$default_name"
    fi

    # ONLY the final value goes to stdout
    printf '%s' "$custom_name"
}

# View database contents
view_database() {
    show_header
    echo -e "${CYAN}📚 Download Database${NC}"
    echo -e "${BLUE}=========================================${NC}"
    
    if [ ! -f "$DATABASE_FILE" ]; then
        echo -e "${RED}❌ No database found${NC}"
        return 1
    fi
    
    python3 << PYEOF
import json
from datetime import datetime

with open('$DATABASE_FILE', 'r') as f:
    data = json.load(f)

print("\n\033[1;35m═══════════════════════════════════════════════════════════\033[0m")
print(f"\033[1;36m📊 Total Downloads:\033[0m {data['metadata']['total_downloads']}")
print(f"\033[1;36m🕐 Last Updated:\033[0m {data['metadata']['last_updated']}")
print("\033[1;35m═══════════════════════════════════════════════════════════\033[0m\n")

sources = ['youtube', 'soundcloud', 'other']
source_icons = {'youtube': '🎥', 'soundcloud': '🔊', 'other': '🌐'}

for source in sources:
    playlists = data[source]['playlists']
    singles = data[source]['singles']
    
    if playlists or singles:
        print(f"\n\033[1;33m{source_icons[source]} {source.upper()}\033[0m")
        print("\033[0;34m─────────────────────────────────────────────────────────\033[0m")
        
        if playlists:
            print(f"\n  \033[0;36m📋 Playlists ({len(playlists)}):\033[0m")
            for idx, item in enumerate(playlists, 1):
                print(f"    \033[0;32m{idx}.\033[0m \033[1m{item['custom_name']}\033[0m")
                print(f"       \033[0;90m{item['title'][:60]}...\033[0m" if len(item['title']) > 60 else f"       \033[0;90m{item['title']}\033[0m")
                print(f"       \033[0;35m🎵 {item['format']}\033[0m | \033[0;34m📅 {item['download_date'][:10]}\033[0m")
        
        if singles:
            print(f"\n  \033[0;36m🎵 Singles ({len(singles)}):\033[0m")
            for idx, item in enumerate(singles, 1):
                print(f"    \033[0;32m{idx}.\033[0m \033[1m{item['custom_name']}\033[0m")
                print(f"       \033[0;90m{item['title'][:60]}...\033[0m" if len(item['title']) > 60 else f"       \033[0;90m{item['title']}\033[0m")
                print(f"       \033[0;35m🎵 {item['format']}\033[0m | \033[0;34m📅 {item['download_date'][:10]}\033[0m")

print("\n\033[1;35m═══════════════════════════════════════════════════════════\033[0m\n")
PYEOF
    
    echo
    read -p "$(echo -e "${GREEN}Press Enter to continue...${NC}")"
}

# Export database as readable format
export_database() {
    show_header
    echo -e "${CYAN}💾 Export Database${NC}"
    echo -e "${BLUE}=========================================${NC}"
    
    local export_file="$CONFIG_DIR/downloads_export_$(date +%Y%m%d_%H%M%S).json"
    cp "$DATABASE_FILE" "$export_file"
    
    echo -e "${GREEN}✅ Database exported to:${NC}"
    echo -e "${YELLOW}$export_file${NC}"
    echo
    read -p "$(echo -e "${GREEN}Press Enter to continue...${NC}")"
}

# Search database
search_database() {
    show_header
    echo -e "${CYAN}🔍 Search Database${NC}"
    echo -e "${BLUE}=========================================${NC}"
    
    read -p "$(echo -e "${GREEN}🔎 Search term: ${NC}")" search_term
    
    if [ -z "$search_term" ]; then
        echo -e "${RED}❌ Search term cannot be empty${NC}"
        sleep 2
        return
    fi
    
    python3 << PYEOF
import json

with open('$DATABASE_FILE', 'r') as f:
    data = json.load(f)

search_term = "$search_term".lower()
found = False

sources = ['youtube', 'soundcloud', 'other']
for source in sources:
    for item in data[source]['playlists'] + data[source]['singles']:
        if search_term in item['title'].lower() or search_term in item['custom_name'].lower():
            if not found:
                print("\n\033[1;32m🎯 Search Results:\033[0m\n")
                found = True
            
            print(f"\033[1;36m{item['custom_name']}\033[0m")
            print(f"  \033[0;90m{item['title']}\033[0m")
            print(f"  \033[0;35m🔗 {item['url']}\033[0m")
            print(f"  \033[0;34m📁 {item['file_path']}\033[0m")
            print(f"  \033[0;33m🎵 {item['format']} | 📅 {item['download_date'][:10]}\033[0m")
            print()

if not found:
    print("\n\033[0;31m❌ No results found\033[0m\n")
PYEOF
    
    echo
    read -p "$(echo -e "${GREEN}Press Enter to continue...${NC}")"
}

# Re-download from database
redownload_from_database() {
    show_header
    echo -e "${CYAN}🔄 Re-download from Database${NC}"
    echo -e "${BLUE}=========================================${NC}"
    
    # List all entries with IDs
    python3 << PYEOF > /tmp/redownload_list.txt
import json

with open('$DATABASE_FILE', 'r') as f:
    data = json.load(f)

sources = ['youtube', 'soundcloud', 'other']
for source in sources:
    for item in data[source]['playlists'] + data[source]['singles']:
        print(f"{item['id']}|{item['custom_name']}|{item['url']}|{item['format']}")
PYEOF
    
    # Display with fzf if available
    if [ "$UI_MODE" = "fzf" ]; then
        selected=$(cat /tmp/redownload_list.txt | awk -F'|' '{printf "%3s %-50s %s\n", $1, $2, $4}' | fzf --height=80% --header="Select item to re-download" | awk '{print $1}')
    else
        # Basic display
        echo -e "${YELLOW}Available downloads:${NC}\n"
        cat /tmp/redownload_list.txt | awk -F'|' '{printf "%3s) %-50s [%s]\n", $1, $2, $4}'
        echo
        read -p "$(echo -e "${GREEN}🔢 Enter ID to re-download: ${NC}")" selected
    fi
    
    if [ -z "$selected" ]; then
        echo -e "${RED}❌ No selection made${NC}"
        sleep 2
        return
    fi
    
    # Get URL and format from selection
    selected_data=$(grep "^${selected}|" /tmp/redownload_list.txt)
    redownload_url=$(echo "$selected_data" | cut -d'|' -f3)
    redownload_format=$(echo "$selected_data" | cut -d'|' -f4)
    
    if [ -z "$redownload_url" ]; then
        echo -e "${RED}❌ Invalid selection${NC}"
        sleep 2
        return
    fi
    
    # Set global variables and download
    url="$redownload_url"
    format="$redownload_format"
    
    echo -e "${GREEN}🔄 Re-downloading...${NC}"
    
    if is_playlist "$url"; then
        download_entire_playlist
    else
        download_single
    fi
}

# Check available UI tools
detect_ui() {
    if command -v fzf &> /dev/null; then
        UI_MODE="fzf"
        echo -e "${GREEN}Using fzf for interface${NC}"
    elif command -v whiptail &> /dev/null; then
        UI_MODE="whiptail"
        echo -e "${YELLOW}Using whiptail for interface${NC}"
    else
        UI_MODE="basic"
        echo -e "${BLUE}Using basic interface${NC}"
    fi
}

# Check dependencies
check_dependencies() {
    local missing_deps=()
    
    if ! command -v yt-dlp &> /dev/null; then
        missing_deps+=("yt-dlp")
    fi
    
    if ! command -v python3 &> /dev/null; then
        missing_deps+=("python3")
    fi
    
    if [ ${#missing_deps[@]} -gt 0 ]; then
        echo -e "${RED}Error: Missing dependencies:${NC}"
        for dep in "${missing_deps[@]}"; do
            echo -e "  ${YELLOW}• $dep${NC}"
        done
        echo
        echo -e "${BLUE}Install yt-dlp from: https://github.com/yt-dlp/yt-dlp${NC}"
        exit 1
    fi
}

# Setup directories
setup_directories() {
    mkdir -p "$MUSIC_DIR"
    mkdir -p "$CONFIG_DIR"
    mkdir -p "$MUSIC_DIR/youtube/playlists"
    mkdir -p "$MUSIC_DIR/youtube/singles"
    mkdir -p "$MUSIC_DIR/soundcloud/playlists"
    mkdir -p "$MUSIC_DIR/soundcloud/singles"
    mkdir -p "$MUSIC_DIR/other/playlists"
    mkdir -p "$MUSIC_DIR/other/singles"
}

# Show fancy header
show_header() {
    clear
    echo -e "${PURPLE}"
    cat << "HEADER"
╔══════════════════════════════════════════════════════════╗
║              🎵 YouTube-DL Audio TUI Enhanced            ║
║            Organized Audio Downloader with JSON          ║
╚══════════════════════════════════════════════════════════╝
HEADER
    echo -e "${NC}"
}

# Main menu
main_menu() {
    show_header
    echo -e "${CYAN}📋 Main Menu${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo
    echo -e "  ${GREEN}1${NC}) ${BOLD}Download New${NC} - Download audio from URL"
    echo -e "  ${GREEN}2${NC}) ${BOLD}View Database${NC} - Browse all downloads"
    echo -e "  ${GREEN}3${NC}) ${BOLD}Search Database${NC} - Find specific downloads"
    echo -e "  ${GREEN}4${NC}) ${BOLD}Re-download${NC} - Download again from database"
    echo -e "  ${GREEN}5${NC}) ${BOLD}Export Database${NC} - Backup your database"
    echo -e "  ${GREEN}6${NC}) ${BOLD}Exit${NC} - Quit application"
    echo
    
    read -p "$(echo -e "${GREEN}🎯 Select option (1-6): ${NC}")" menu_choice
    
    case $menu_choice in
        1) download_workflow ;;
        2) view_database ;;
        3) search_database ;;
        4) redownload_from_database ;;
        5) export_database ;;
        6) 
            echo -e "${CYAN}👋 Thanks for using ytdlp-tui-enhanced!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}❌ Invalid choice!${NC}"
            sleep 1
            ;;
    esac
}

# Get URL with fancy prompt
get_url() {
    show_header
    echo -e "${CYAN}📥 Enter Video/Playlist URL${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo -e "${YELLOW}Supported: YouTube, SoundCloud, Bandcamp, etc.${NC}"
    echo
    read -p "$(echo -e "${GREEN}🔗 URL: ${NC}")" url
    
    if [ -z "$url" ]; then
        echo -e "${RED}❌ URL cannot be empty!${NC}"
        sleep 2
        return 1
    fi
    
    # Detect source
    DOWNLOAD_META[source]=$(detect_source "$url")
    
    # Check if playlist
    if is_playlist "$url"; then
        DOWNLOAD_META[type]="playlist"
    else
        DOWNLOAD_META[type]="single"
    fi
    
    echo -e "${GREEN}✅ Detected: ${DOWNLOAD_META[source]} ${DOWNLOAD_META[type]}${NC}"
    sleep 1
    return 0
}

# Select format based on UI mode
select_format() {
    case $UI_MODE in
        "fzf")
            select_format_fzf
            ;;
        "whiptail")
            select_format_whiptail
            ;;
        "basic")
            select_format_basic
            ;;
    esac
}

select_format_fzf() {
    show_header
    echo -e "${CYAN}🎼 Select Audio Format${NC}"
    echo -e "${BLUE}=========================================${NC}"
    
    format=$(printf "mp3\tMP3 format (most compatible)\nm4a\tM4A format (Apple devices)\nopus\tOpus format (high quality)\nflac\tFLAC format (lossless)\nwav\tWAV format (uncompressed)" | fzf --height=40% --header="Select audio format:" --delimiter=$'\t' --with-nth=1,2 | cut -f1)
    
    if [ -z "$format" ]; then
        echo -e "${RED}No format selected, using mp3${NC}"
        format="mp3"
    fi
}

select_format_whiptail() {
    format=$(whiptail --title "Select Audio Format" --menu "Choose download format:" 15 50 5 \
        "mp3" "MP3 format (most compatible)" \
        "m4a" "M4A format (Apple devices)" \
        "opus" "Opus format (high quality)" \
        "flac" "FLAC format (lossless)" \
        "wav" "WAV format (uncompressed)" 3>&1 1>&2 2>&3)
    
    if [ $? -ne 0 ] || [ -z "$format" ]; then
        format="mp3"
    fi
}

select_format_basic() {
    show_header
    echo -e "${CYAN}🎼 Select Audio Format${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo
    echo -e "  ${GREEN}1${NC}) ${BOLD}mp3${NC}  - MP3 format (most compatible)"
    echo -e "  ${GREEN}2${NC}) ${BOLD}m4a${NC}  - M4A format (Apple devices)"
    echo -e "  ${GREEN}3${NC}) ${BOLD}opus${NC} - Opus format (high quality)"
    echo -e "  ${GREEN}4${NC}) ${BOLD}flac${NC} - FLAC format (lossless)"
    echo -e "  ${GREEN}5${NC}) ${BOLD}wav${NC}  - WAV format (uncompressed)"
    echo
    
    while true; do
        read -p "$(echo -e "${GREEN}🎵 Select format (1-5): ${NC}")" format_choice
        
        case $format_choice in
            1) format="mp3"; break ;;
            2) format="m4a"; break ;;
            3) format="opus"; break ;;
            4) format="flac"; break ;;
            5) format="wav"; break ;;
            *) echo -e "${RED}❌ Invalid choice! Please enter 1-5${NC}" ;;
        esac
    done
}

# Get playlist info
get_playlist_info() {
    echo -e "${YELLOW}📋 Fetching playlist info...${NC}"
    
    # Get playlist title
    playlist_title=$(yt-dlp --flat-playlist --print "%(playlist_title)s" "$url" 2>/dev/null | head -1)
    
    if [ -z "$playlist_title" ]; then
        playlist_title="Unknown Playlist"
    fi
    
    DOWNLOAD_META[playlist_title]="$playlist_title"
    
    # Get video info
    playlist_info=$(yt-dlp --flat-playlist --print "%(title)s|||%(duration)s|||%(uploader)s" "$url" 2>/dev/null)
    
    if [ $? -ne 0 ] || [ -z "$playlist_info" ]; then
        return 1
    fi
    
    # Parse into arrays
    IFS=$'\n' read -d '' -r -a video_data <<< "$playlist_info"
    
    titles=()
    durations=()
    uploaders=()
    
    for line in "${video_data[@]}"; do
        IFS='|||' read -r title duration uploader <<< "$line"
        titles+=("$title")
        durations+=("$duration")
        uploaders+=("$uploader")
    done
    
    return 0
}

# Select playlist items based on UI mode
select_playlist_items() {
    case $UI_MODE in
        "fzf")
            select_playlist_items_fzf
            ;;
        "whiptail")
            select_playlist_items_whiptail
            ;;
        "basic")
            select_playlist_items_basic
            ;;
    esac
}

select_playlist_items_fzf() {
    show_header
    echo -e "${CYAN}🎵 Select Playlist Items${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo -e "${PURPLE}Playlist: ${DOWNLOAD_META[playlist_title]}${NC}"
    echo
    
    # Prepare data for fzf
    > /tmp/playlist_items.txt
    for i in "${!titles[@]}"; do
        duration=${durations[$i]:-"Unknown"}
        uploader=${uploaders[$i]:-"Unknown"}
        printf "%-3s %-60s %-8s %s\n" "$((i+1))" "${titles[$i]}" "$duration" "$uploader" >> /tmp/playlist_items.txt
    done
    
    selected=$(cat /tmp/playlist_items.txt | fzf --multi --height=80% --header="Select videos (Tab to select, Enter to confirm, or ESC for all)" | awk '{print $1}')
    
    if [ -z "$selected" ]; then
        echo -e "${YELLOW}No items selected, downloading entire playlist${NC}"
        return 0
    fi
    
    # Convert to comma-separated list
    DOWNLOAD_META[selection]=$(echo "$selected" | tr '\n' ',' | sed 's/,$//')
    return 1
}

select_playlist_items_whiptail() {
    # Build whiptail menu items
    menu_items=()
    for i in "${!titles[@]}"; do
        menu_items+=("$((i+1))" "${titles[$i]:0:50}" "OFF")
    done
    
    selected=$(whiptail --title "Select Videos" --checklist "Choose videos to download (Space to select, Enter to confirm):" 20 70 12 "${menu_items[@]}" 3>&1 1>&2 2>&3)
    
    if [ $? -ne 0 ] || [ -z "$selected" ]; then
        echo -e "${YELLOW}No items selected, downloading entire playlist${NC}"
        return 0
    fi
    
    # Parse whiptail output and convert to comma-separated
    DOWNLOAD_META[selection]=$(echo "$selected" | sed 's/"//g' | sed 's/ /,/g')
    return 1
}

select_playlist_items_basic() {
    show_header
    echo -e "${CYAN}🎵 Playlist Items${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo -e "${PURPLE}Playlist: ${DOWNLOAD_META[playlist_title]}${NC}"
    echo
    
    for i in "${!titles[@]}"; do
        duration=${durations[$i]:-"Unknown"}
        echo -e "  ${GREEN}$((i+1))${NC}) ${titles[$i]}"
        echo -e "      ${BLUE}⏱ ${duration}s${NC} | ${PURPLE}👤 ${uploaders[$i]}${NC}"
    done
    
    echo
    echo -e "${YELLOW}Enter video numbers (e.g., 1 3 5) or 'all' for everything:${NC}"
    read -p "$(echo -e "${GREEN}🎯 Selection: ${NC}")" selection
    
    if [ "$selection" = "all" ] || [ -z "$selection" ]; then
        return 0
    else
        # Convert space-separated to comma-separated
        DOWNLOAD_META[selection]=$(echo "$selection" | tr ' ' ',')
        return 1
    fi
}

# Download single video
download_single() {
    local source="${DOWNLOAD_META[source]}"
    local save_dir="$MUSIC_DIR/$source/singles"
    
    # Get video title first
    echo -e "${YELLOW}🔍 Fetching video info...${NC}"
    video_title=$(yt-dlp --print "%(title)s" "$url" 2>/dev/null | head -1)
    
    if [ -z "$video_title" ]; then
        video_title="Unknown Title"
    fi
    
    # Get custom name
    custom_name=$(get_custom_name "$video_title")
    
    show_header
    echo -e "${CYAN}🚀 Starting Download${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo -e "${GREEN}📁 Location:${NC} $save_dir"
    echo -e "${GREEN}🎵 Format:${NC} $format"
    echo -e "${GREEN}📝 Name:${NC} $custom_name"
    echo -e "${GREEN}🔗 URL:${NC} $url"
    echo
    echo -e "${YELLOW}⬇️  Downloading...${NC}"
    echo "──────────────────────────────────────────────────"
    
    cd "$save_dir"
    yt-dlp -x \
        --audio-format "$format" \
        --audio-quality 0 \
        --embed-metadata \
        --embed-thumbnail \
        -o "%(title)s.%(ext)s" \
        "$url"
    
    local result=$?
    
    if [ $result -eq 0 ]; then
        # Find the downloaded file
        local downloaded_file=$(ls -t "$save_dir" | head -1)
        local file_path="$save_dir/$downloaded_file"
        
        # Add to database
        add_to_database "$source" "singles" "$url" "$video_title" "$custom_name" "$format" "$file_path"
        
        echo
        echo "──────────────────────────────────────────────────"
        echo -e "${GREEN}✅ Download completed successfully!${NC}"
        echo -e "${BLUE}📁 Files saved to: $save_dir${NC}"
        echo -e "${GREEN}💾 Added to database${NC}"
    else
        echo
        echo "──────────────────────────────────────────────────"
        echo -e "${RED}❌ Download failed with error code: $result${NC}"
    fi
}

# Download entire playlist
download_entire_playlist() {
    local source="${DOWNLOAD_META[source]}"
    local playlist_title="${DOWNLOAD_META[playlist_title]}"
    local save_dir="$MUSIC_DIR/$source/playlists"
    
    # Get custom name for playlist
    custom_name=$(get_custom_name "$playlist_title")
    
    # Create sanitized folder name
    local folder_name=$(echo "$custom_name" | sed 's/[^a-zA-Z0-9 _-]//g')
    local full_save_dir="$save_dir/$folder_name"
    
    show_header
    echo -e "${CYAN}🚀 Downloading Entire Playlist${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo -e "${GREEN}📁 Location:${NC} $full_save_dir"
    echo -e "${GREEN}🎵 Format:${NC} $format"
    echo -e "${GREEN}📝 Name:${NC} $custom_name"
    echo -e "${GREEN}📋 Videos:${NC} ${#titles[@]}"
    echo -e "${GREEN}🔗 URL:${NC} $url"
    echo
    echo -e "${YELLOW}⬇️  Downloading...${NC}"
    echo "──────────────────────────────────────────────────"
    
    mkdir -p "$full_save_dir"
    cd "$full_save_dir"
    
    yt-dlp -x \
        --audio-format "$format" \
        --audio-quality 0 \
        --embed-metadata \
        --embed-thumbnail \
        -o "%(title)s.%(ext)s" \
        "$url"
    
    local result=$?
    
    if [ $result -eq 0 ]; then
        # Add to database
        add_to_database "$source" "playlists" "$url" "$playlist_title" "$custom_name" "$format" "$full_save_dir"
        
        echo
        echo "──────────────────────────────────────────────────"
        echo -e "${GREEN}✅ Playlist download completed successfully!${NC}"
        echo -e "${BLUE}📁 Files saved to: $full_save_dir${NC}"
        echo -e "${GREEN}💾 Added to database${NC}"
    else
        echo
        echo "──────────────────────────────────────────────────"
        echo -e "${RED}❌ Download failed with error code: $result${NC}"
    fi
}

# Download selected videos from playlist
download_selected_videos() {
    local source="${DOWNLOAD_META[source]}"
    local playlist_title="${DOWNLOAD_META[playlist_title]}"
    local selection="${DOWNLOAD_META[selection]}"
    local save_dir="$MUSIC_DIR/$source/playlists"
    
    # Get custom name for selection
    custom_name=$(get_custom_name "$playlist_title (Selected)")
    
    # Create sanitized folder name
    local folder_name=$(echo "$custom_name" | sed 's/[^a-zA-Z0-9 _-]//g')
    local full_save_dir="$save_dir/$folder_name"
    
    show_header
    echo -e "${CYAN}🚀 Downloading Selected Videos${NC}"
    echo -e "${BLUE}=========================================${NC}"
    echo -e "${GREEN}📁 Location:${NC} $full_save_dir"
    echo -e "${GREEN}🎵 Format:${NC} $format"
    echo -e "${GREEN}📝 Name:${NC} $custom_name"
    echo -e "${GREEN}🎯 Selected:${NC} $selection"
    echo -e "${GREEN}🔗 URL:${NC} $url"
    echo
    echo -e "${YELLOW}⬇️  Downloading...${NC}"
    echo "──────────────────────────────────────────────────"
    
    mkdir -p "$full_save_dir"
    cd "$full_save_dir"
    
    yt-dlp -x \
        --audio-format "$format" \
        --audio-quality 0 \
        --embed-metadata \
        --embed-thumbnail \
        --playlist-items "$selection" \
        -o "%(title)s.%(ext)s" \
        "$url"
    
    local result=$?
    
    if [ $result -eq 0 ]; then
        # Add to database
        add_to_database "$source" "playlists" "$url" "$playlist_title (Selected: $selection)" "$custom_name" "$format" "$full_save_dir"
        
        echo
        echo "──────────────────────────────────────────────────"
        echo -e "${GREEN}✅ Selected videos downloaded successfully!${NC}"
        echo -e "${BLUE}📁 Files saved to: $full_save_dir${NC}"
        echo -e "${GREEN}💾 Added to database${NC}"
    else
        echo
        echo "──────────────────────────────────────────────────"
        echo -e "${RED}❌ Download failed with error code: $result${NC}"
    fi
}

# Download workflow
download_workflow() {
    # Get URL
    if ! get_url; then
        return
    fi
    
    # Select format
    select_format
    
    # Handle based on type
    if [ "${DOWNLOAD_META[type]}" = "playlist" ]; then
        if get_playlist_info; then
            if select_playlist_items; then
                # User wants entire playlist
                download_entire_playlist
            else
                # User selected specific videos
                download_selected_videos
            fi
        else
            echo -e "${RED}❌ Failed to fetch playlist info${NC}"
            echo -e "${YELLOW}Trying to download as single video...${NC}"
            DOWNLOAD_META[type]="single"
            download_single
        fi
    else
        download_single
    fi
    
    echo
    read -p "$(echo -e "${GREEN}Press Enter to continue...${NC}")"
}

# Main function
main() {
    detect_ui
    check_dependencies
    setup_directories
    init_database
    
    while true; do
        main_menu
    done
}

# Handle Ctrl+C gracefully
trap 'echo -e "\n${RED}👋 Exiting...${NC}"; exit 0' INT

# Run main function
main
