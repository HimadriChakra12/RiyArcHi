# Wrapper for pacman (with sudo)
pacman() {
    local args=("$@")
    local is_install=false
    local is_remove=false
    local packages=()
    
    for arg in "${args[@]}"; do
        case "$arg" in
            -S|--sync|-U|--upgrade)
                is_install=true
                ;;
            -R|--remove|-Rs|-Rns|-Rn)
                is_remove=true
                ;;
        esac
    done
    
    # Pacman usually needs sudo for install/remove
    if [[ "$is_install" == "true" ]] || [[ "$is_remove" == "true" ]]; then
        sudo command pacman "$@"
    else
        command pacman "$@"
    fi
    local exit_code=$?
    
    if [[ $exit_code -eq 0 ]] && [[ "$PKGBACK_ENABLED" == "true" ]]; then
        if [[ "$is_install" == "true" ]] || [[ "$is_remove" == "true" ]]; then
            local skip_next=false
            for arg in "${args[@]}"; do
                if [[ "$skip_next" == "true" ]]; then
                    skip_next=false
                    continue
                fi
                
                case "$arg" in
                    -S|-U|-R|--sync|--upgrade|--remove|-Rs|-Rns|-Rn)
                        continue
                        ;;
                    --config|--dbpath|--root|--arch|--cachedir|--gpgdir|--hookdir|--logfile)
                        skip_next=true
                        continue
                        ;;
                    -*)
                        continue
                        ;;
                    *)
                        packages+=("$arg")
                        ;;
                esac
            done
            
            if [[ ${#packages[@]} -gt 0 ]]; then
                if [[ "$is_install" == "true" ]]; then
                    _pkgback_track "install" "${packages[@]}"
                else
                    _pkgback_track "remove" "${packages[@]}"
                fi
            fi
        fi
    fi
    
    return $exit_code
}

# Helper functions
pkgback() {
    case "${1:-help}" in
        enable)
            export PKGBACK_ENABLED=true
            echo -e "${_pkgback_green}✓ Package tracking enabled${_pkgback_nc}"
            ;;
        disable)
            export PKGBACK_ENABLED=false
            echo -e "${_pkgback_yellow}✗ Package tracking disabled${_pkgback_nc}"
            ;;
        status)
            echo -e "${_pkgback_blue}pkgback status:${_pkgback_nc}"
            echo "  Enabled: $PKGBACK_ENABLED"
            echo "  Directory: $PKGBACK_DIR"
            echo "  Shell: $PKGBACK_SHELL"
            local install_count=$(ls -1 "$PKGBACK_TRACK_DIR"/install_*.json 2>/dev/null | wc -l)
            local remove_count=$(ls -1 "$PKGBACK_TRACK_DIR"/remove_*.json 2>/dev/null | wc -l)
            echo "  Installations tracked: $install_count"
            echo "  Removals tracked: $remove_count"
            ;;
        export)
            local output="${2:-$HOME/packages_export_$(date +%Y%m%d).json}"
            if [[ -f "$PKGBACK_DIR/packages_current.json" ]]; then
                cp "$PKGBACK_DIR/packages_current.json" "$output"
                echo -e "${_pkgback_green}✓ Exported to: $output${_pkgback_nc}"
            else
                echo -e "${_pkgback_yellow}No current package list found${_pkgback_nc}"
            fi
            ;;
        clean)
            local keep="${2:-10}"
            echo -e "${_pkgback_blue}Keeping $keep most recent installations...${_pkgback_nc}"
            ls -t "$PKGBACK_TRACK_DIR"/install_*.json 2>/dev/null | tail -n +$((keep + 1)) | while read -r file; do
                rm "$file"
                echo "  Removed: $(basename "$file")"
            done
            ;;
        help)
            echo "pkgback - Automatic Package Tracking"
            echo ""
            echo "Usage:"
            echo "  source pkgback           # Enable tracking"
            echo "  pkgback enable           # Enable tracking"
            echo "  pkgback disable          # Disable tracking"
            echo "  pkgback status           # Show status"
            echo "  pkgback export [file]    # Export current packages"
            echo "  pkgback clean [N]        # Keep only N recent records (default: 10)"
            echo ""
            echo "After sourcing, just use your package manager normally:"
            echo "  yay -S firefox           # Install - automatically tracked!"
            echo "  yay -R firefox           # Remove - automatically tracked!"
            echo "  paru -S neovim           # Install - automatically tracked!"
            echo "  pacman -Rs package       # Remove - automatically tracked!"
            echo ""
            echo "Files saved to: $PKGBACK_DIR"
            echo ""
            echo "To list your packages, use your package manager:"
            echo "  pacman -Q                # List all installed packages"
            echo "  pacman -Qe               # List explicitly installed"
            echo "  yay -Q                   # Also works with AUR helpers"
            ;;
        *)
            echo "Unknown command: $1"
            echo "Run 'pkgback help' for usage"
            ;;
    esac
}

# Auto-clean old records (keep last 50)
_pkgback_autoclean() {
    local count=$(ls -1 "$PKGBACK_TRACK_DIR"/{install,remove}_*.json 2>/dev/null | wc -l)
    if [[ $count -gt 50 ]]; then
        ls -t "$PKGBACK_TRACK_DIR"/{install,remove}_*.json 2>/dev/null | tail -n +51 | xargs -r rm --
    fi
}

# Run autoclean in background
(_pkgback_autoclean &) 2>/dev/null

# Show loaded message
if [[ "$PKGBACK_ENABLED" == "true" ]]; then
    echo -e "${_pkgback_green}✓ pkgback loaded${_pkgback_nc} - Package installations will be tracked automatically"
    echo -e "  Run ${_pkgback_blue}pkgback help${_pkgback_nc} for commands"
fi
