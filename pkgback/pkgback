#!/bin/bash
# pkgback - Source this file to automatically track package installations
# Usage: source pkgback (add to ~/.bashrc or ~/.zshrc)

# Configuration
export PKGBACK_DIR="${PKGBACK_DIR:-$HOME/.local/share/pkgback}"
export PKGBACK_TRACK_DIR="$PKGBACK_DIR/installations"
export PKGBACK_ENABLED="${PKGBACK_ENABLED:-true}"

# Create directories
mkdir -p "$PKGBACK_TRACK_DIR"

# Detect shell
if [ -n "$BASH_VERSION" ]; then
    PKGBACK_SHELL="bash"
elif [ -n "$ZSH_VERSION" ]; then
    PKGBACK_SHELL="zsh"
else
    PKGBACK_SHELL="unknown"
fi

# Colors
_pkgback_green='\033[0;32m'
_pkgback_blue='\033[0;34m'
_pkgback_yellow='\033[1;33m'
_pkgback_nc='\033[0m'

# Track installation function
_pkgback_track() {
    local operation="$1"
    shift
    local packages=("$@")
    local timestamp=$(date +"%Y%m%d_%H%M%S")
    local date_iso=$(date -Iseconds)
    
    # Determine which package manager was actually used
    local pm_name="pacman"
    [[ "${FUNCNAME[2]}" == "yay" ]] && pm_name="yay"
    [[ "${FUNCNAME[2]}" == "paru" ]] && pm_name="paru"
    [[ "${FUNCNAME[2]}" == "pikaur" ]] && pm_name="pikaur"
    
    # Create installation/removal record
    local record_file="$PKGBACK_TRACK_DIR/${operation}_${timestamp}.json"
    
    {
        echo "{"
        echo "  \"timestamp\": \"$date_iso\","
        echo "  \"operation\": \"$operation\","
        echo "  \"package_manager\": \"$pm_name\","
        echo "  \"hostname\": \"$(hostname)\","
        echo "  \"user\": \"$USER\","
        echo "  \"shell\": \"$PKGBACK_SHELL\","
        echo "  \"requested_packages\": ["
        
        local first=true
        for pkg in "${packages[@]}"; do
            [[ "$first" == "true" ]] && first=false || echo ","
            echo -n "    \"$pkg\""
        done
        
        echo ""
        echo "  ],"
        echo "  \"installed_packages\": ["
        
        first=true
        pacman -Qe 2>/dev/null | while read -r pkg_name pkg_version; do
            [[ "$first" == "true" ]] && first=false || echo ","
            echo -n "    {\"name\": \"$pkg_name\", \"version\": \"$pkg_version\"}"
        done
        
        echo ""
        echo "  ]"
        echo "}"
    } > "$record_file"
    
    # Update current package list
    local export_file="$PKGBACK_DIR/packages_current.json"
    
    {
        echo "{"
        echo "  \"export_date\": \"$date_iso\","
        echo "  \"hostname\": \"$(hostname)\","
        echo "  \"package_manager\": \"$pm_name\","
        echo "  \"auto_export\": true,"
        echo "  \"packages\": ["
        
        first=true
        pacman -Qe 2>/dev/null | while read -r pkg_name pkg_version; do
            [[ "$first" == "true" ]] && first=false || echo ","
            echo -n "    {\"name\": \"$pkg_name\", \"version\": \"$pkg_version\"}"
        done
        
        echo ""
        echo "  ]"
        echo "}"
    } > "$export_file"
    
    # Pretty print if jq available
    if command -v jq &>/dev/null; then
        jq '.' "$record_file" > "${record_file}.tmp" 2>/dev/null && mv "${record_file}.tmp" "$record_file"
        jq '.' "$export_file" > "${export_file}.tmp" 2>/dev/null && mv "${export_file}.tmp" "$export_file"
    fi
    
    # Show notification
    if [[ "$operation" == "install" ]]; then
        echo -e "${_pkgback_green}✓ Installed & tracked:${_pkgback_nc} ${packages[*]}" >&2
    else
        echo -e "${_pkgback_yellow}✓ Removed & tracked:${_pkgback_nc} ${packages[*]}" >&2
    fi
    echo -e "${_pkgback_blue}  Saved to: $record_file${_pkgback_nc}" >&2
}

# Wrapper for yay
yay() {
    local args=("$@")
    local is_install=false
    local is_remove=false
    local packages=()
    
    # Check if this is an install or remove operation
    for arg in "${args[@]}"; do
        case "$arg" in
            -S|--sync|-U|--upgrade)
                is_install=true
                ;;
            -R|--remove|-Rs|-Rns|-Rn)
                is_remove=true
                ;;
        esac
    done
    
    # Run the real yay
    command yay "$@"
    local exit_code=$?
    
    # Track if successful operation
    if [[ $exit_code -eq 0 ]] && [[ "$PKGBACK_ENABLED" == "true" ]]; then
        if [[ "$is_install" == "true" ]] || [[ "$is_remove" == "true" ]]; then
            # Extract package names
            local skip_next=false
            for arg in "${args[@]}"; do
                if [[ "$skip_next" == "true" ]]; then
                    skip_next=false
                    continue
                fi
                
                case "$arg" in
                    -S|-U|-R|--sync|--upgrade|--remove|-Rs|-Rns|-Rn)
                        continue
                        ;;
                    --config|--dbpath|--root|--arch|--cachedir|--gpgdir|--hookdir|--logfile)
                        skip_next=true
                        continue
                        ;;
                    -*)
                        continue
                        ;;
                    *)
                        packages+=("$arg")
                        ;;
                esac
            done
            
            # Track if we have packages
            if [[ ${#packages[@]} -gt 0 ]]; then
                if [[ "$is_install" == "true" ]]; then
                    _pkgback_track "install" "${packages[@]}"
                else
                    _pkgback_track "remove" "${packages[@]}"
                fi
            fi
        fi
    fi
    
    return $exit_code
}

